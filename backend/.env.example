# Environment variables - Copy this to .env and fill in your values

# App
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/pawmind
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/pawmind

# File Storage
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# ML Model
MODEL_PATH=./ml/model.onnx
MODEL_VERSION=v1

# Groq (AI Chat)
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
